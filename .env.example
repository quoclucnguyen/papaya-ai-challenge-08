# Required: create a key at https://openrouter.ai/keys
# Required: create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vision-capable model. Override this without changing code.
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional OpenRouter configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_TOKENS=4096
# Retries per request. On retry, forced JSON mode is dropped so weaker vision
# models stop looping/truncating; the response is parsed leniently instead.
OPENROUTER_MAX_ATTEMPTS=3
OPENROUTER_APP_URL=http://localhost
OPENROUTER_APP_TITLE=Medical Document Extractor
